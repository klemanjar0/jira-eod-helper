# Supabase — required
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_...

# Jira — required
# Used by the server-side proxy (app/api/[...path])
NEXT_PUBLIC_JIRA_HOST=https://your-org.atlassian.net
# Used by server actions to call Jira directly
NEXT_PUBLIC_API_URL=https://your-org.atlassian.net

# App URL — required for CORS restriction on the Jira proxy
# Set to the publicly accessible URL of this app
NEXT_PUBLIC_APP_URL=https://your-app.example.com

# Master Jira credentials — optional
# When a user enables "master key" mode, these are used instead of their personal API token
MASTER_EMAIL=admin@your-org.com
MASTER_API_TOKEN=your-jira-api-token
